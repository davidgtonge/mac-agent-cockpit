{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Cockpit",
  "version": "0.1.0-alpha.1",
  "identifier": "dev.agent-cockpit.mac",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Cockpit",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Agent Cockpit",
        "url": "splashscreen.html",
        "width": 360,
        "height": 280,
        "center": true,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true,
        "alwaysOnTop": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
